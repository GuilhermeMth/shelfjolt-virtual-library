generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int        @id @default(autoincrement())
  name         String     
  email        String     @unique
  password     String?
  google_id    String?
  
  publications Book[]     @relation("UserPublications")
  myShelf      SaveBook[] @relation("UserShelf")
  
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("users")
}

model Book {
  id          Int             @id @default(autoincrement())
  title       String
  slug        String          @unique
  description String?         @db.Text
  
  fileUrl     String
  coverPath   String?

  language    String
  viewCount   Int             @default(0)

  authorId    Int
  published   DateTime        @default(now())
  
  author      User            @relation("UserPublications", fields: [authorId], references: [id])
  categories  BookCategory[]  @relation("BookCategories")
  savedBy     SaveBook[]      @relation("BookInShelf")
  
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([authorId])
  @@index([title])
  @@map("books")
}

model Category {
  id        Int            @id @default(autoincrement())
  name      String         @unique
  
  books     BookCategory[] @relation("CategoryBooks")
  
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@map("categories")
}

model BookCategory {
  id         Int      @id @default(autoincrement())
  bookId     Int
  categoryId Int

  book       Book     @relation("BookCategories", fields: [bookId], references: [id], onDelete: Cascade)
  category   Category @relation("CategoryBooks", fields: [categoryId], references: [id], onDelete: Cascade)
  
  createdAt  DateTime @default(now())

  @@unique([bookId, categoryId])
  @@index([bookId])
  @@index([categoryId])
  @@map("book_categories")
}

model SaveBook {
  id        Int      @id @default(autoincrement())
  userId    Int
  bookId    Int

  user      User     @relation("UserShelf", fields: [userId], references: [id])
  book      Book     @relation("BookInShelf", fields: [bookId], references: [id])
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, bookId])
  @@map("save_books")
}
